# MandingoForge - Comprehensive .gitignore (Sprint 0+)

# Dependencies
node_modules/
frontend/node_modules/

# Build outputs
dist/
frontend/dist/
target/
src-tauri/target/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Local env / secrets
.env
.env.local
*.local

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store

# Models & User Data (large binaries - NEVER commit)
models/
models/**
!models/.gitkeep
gallery/
gallery/**
!gallery/.gitkeep
comfyui/
comfyui/**
!comfyui/.gitkeep

# Training datasets (user private)
datasets/
training/

# OS / temp
Thumbs.db
ehthumbs.db
Desktop.ini

# Python / ComfyUI cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Rust
Cargo.lock  # optional - keep for reproducible builds (we keep it)
# If you prefer not to commit lock, uncomment above

# Misc
*.bak
*.tmp
