{
  "name": "mandingo-forge",
  "private": true,
  "version": "0.1.0",
  "description": "MandingoForge - Professional desktop AI generative studio for gay interracial, BBC, raceplay, and Mandingo-themed art",
  "scripts": {
    "install:all": "npm install && npm --prefix frontend install",
    "dev": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "tauri build --config src-tauri/tauri.conf.json",
    "tauri:info": "tauri info"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}